{
  "name": "ecommerce-microservice",
  "version": "0.0.1",
  "description": "RabbitMQ-based ecommerce microservice (NestJS)",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:order-service": "nest build order-service",
    "build:inventory-service": "nest build inventory-service",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"*.{json,md,mjs,yml,yaml}\"",
    "format:check": "prettier --check \"apps/**/*.ts\" \"libs/**/*.ts\" \"*.{json,md,mjs,yml,yaml}\"",
    "dev:order-service": "nest start order-service --watch",
    "dev:inventory-service": "nest start inventory-service --watch",
    "debug:order-service": "nest start order-service --debug --watch",
    "debug:inventory-service": "nest start inventory-service --debug --watch",
    "prod:order-service": "node dist/apps/order-service/main",
    "prod:inventory-service": "node dist/apps/inventory-service/main",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "joi": "^17.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@app/common/(.*)$": "<rootDir>/libs/common/src/$1"
    },
    "roots": ["<rootDir>/apps/", "<rootDir>/libs/"]
  }
}
